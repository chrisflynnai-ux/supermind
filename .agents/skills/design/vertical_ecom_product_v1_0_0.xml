<?xml version="1.0" encoding="UTF-8"?>
<!--
  VERTICAL: ECOM PRODUCT PAGE v1.0.0
  Design skill for high-converting product detail pages (PDP)
  
  EXTENDS:
  - design_core_v1.0.0 (universal foundation)
  - conversion_core_patterns (trust + CTA patterns)
  - style_ecom_product (recommended)
  
  PURPOSE:
  Transform product pages from "photo albums" into "offer presentations"
  that maximize conversion rate and average order value (AOV).
  
  EXTRACTED FROM: NotebookLM analysis of D2C/DTC product pages
  
  VERSION: 1.0.0
  UPDATED: 2026-02-09
-->

<VerticalSkill
  skill_id="skill.vertical_ecom_product.v1_0_0"
  name="Ecom Product Page"
  version="1.0.0"
  tier="vertical"
  status="active"
>

  <Meta>
    <Extends>design_core_v1.0.0, conversion_core_patterns</Extends>
    <RecommendedStyles>style_ecom_product, style_minimal_clean</RecommendedStyles>
    <TokenBudget>~650 tokens when loaded</TokenBudget>
    <SwipeDerivation>D2C supplement, beauty, and lifestyle brand analysis</SwipeDerivation>
  </Meta>

  <!-- ================================================================== -->
  <!-- PAGE ARCHETYPE                                                      -->
  <!-- ================================================================== -->
  
  <PageArchetype>
    <Purpose>
      Convert browsers into buyers by constructing a high-converting OFFER,
      not just displaying a product. Maximize both CVR and AOV.
    </Purpose>
    
    <CorePrinciple>
      The gallery is a slide deck, not a photo album.
      The buy box is an offer, not just a price.
      Every element reduces friction or builds desire.
    </CorePrinciple>
    
    <ConversionGoals>
      <Primary>Add to Cart (highest value bundle)</Primary>
      <Secondary>Subscribe &amp; Save enrollment</Secondary>
      <Tertiary>Increase AOV via cross-sell/upsell</Tertiary>
    </ConversionGoals>
  </PageArchetype>

  <!-- ================================================================== -->
  <!-- PRODUCT HERO & GALLERY                                              -->
  <!-- ================================================================== -->
  
  <ProductGallery>
    <Philosophy>Use gallery as slide-deck presentation, not photo album</Philosophy>
    
    <SixSlideFramework>
      <Slide position="1" name="hero_shot">
        <Content>High-res product image</Content>
        <Overlay>Value-driven headline (optional)</Overlay>
        <Purpose>Visual hook, product beauty</Purpose>
      </Slide>
      
      <Slide position="2" name="benefit_result">
        <Content>Visual representation of outcome</Content>
        <Examples>
          <Example>"Pale to Tan in Minutes"</Example>
          <Example>"Eliminate Wrinkles"</Example>
          <Example>Before/After comparison</Example>
        </Examples>
        <Purpose>Show transformation, not just product</Purpose>
      </Slide>
      
      <Slide position="3" name="mechanism_howto">
        <Content>Simple 1-2-3 step visual guide</Content>
        <Format>"Apply → Wait → Rinse"</Format>
        <Purpose>Demystify usage, reduce friction</Purpose>
      </Slide>
      
      <Slide position="4" name="social_proof">
        <Content>Screenshot of 5-star review OR Before/After</Content>
        <Format>Real screenshot, not recreated</Format>
        <Purpose>Proof at point of consideration</Purpose>
      </Slide>
      
      <Slide position="5" name="comparison">
        <Content>"Us vs. Them" chart</Content>
        <Format>Checkmarks vs X's, visual striking</Format>
        <Purpose>Competitive differentiation</Purpose>
      </Slide>
      
      <Slide position="6" name="risk_reversal">
        <Content>Guarantee seal graphic</Content>
        <Examples>"30-Day Money Back Guarantee"</Examples>
        <Purpose>Reduce purchase anxiety</Purpose>
      </Slide>
    </SixSlideFramework>
    
    <VideoIntegration>
      <Thumbnail>Play icon overlay on 3rd or 4th slide</Thumbnail>
      <Duration>Under 15 seconds</Duration>
      <Content>Texture, application, or reaction (UGC style)</Content>
      <Behavior>Click to play, never autoplay</Behavior>
    </VideoIntegration>
  </ProductGallery>

  <!-- ================================================================== -->
  <!-- BUY BOX ARCHITECTURE                                                -->
  <!-- ================================================================== -->
  
  <BuyBox>
    <Philosophy>Construct an OFFER, not just display a price</Philosophy>
    
    <ReviewSummary placement="above_title">
      <Format>★★★★★ 4.8/5 (1,240 Reviews)</Format>
      <Behavior>Click → smooth scroll to reviews widget</Behavior>
      <Purpose>Anchor high value before reading title</Purpose>
    </ReviewSummary>
    
    <ProductTitle>
      <Formula>Benefit + Product Name</Formula>
      <Avoid>"Vitamin C Serum" (generic)</Avoid>
      <Use>"Vitamin C Serum: Brightens Skin in 7 Days"</Use>
      <Subtitle>1-sentence hook below title</Subtitle>
      <SubtitleExample>"The only serum backed by 3 clinical trials"</SubtitleExample>
    </ProductTitle>
    
    <PriceDisplay>
      <Anchoring required="true">
        <Format>$̶1̶2̶0̶ → $79</Format>
        <Rule>Always show MSRP strikethrough</Rule>
      </Anchoring>
      
      <MicroPricing>
        <Format>"$1.50/day" or "$0.50/serving"</Format>
        <Placement>Small text near total price</Placement>
        <Purpose>Reframe large purchase as trivial daily cost</Purpose>
      </MicroPricing>
      
      <PaymentOptions>
        <Logos>Afterpay, Klarna, Affirm</Logos>
        <Copy>"4 interest-free payments of $17.48"</Copy>
        <Placement>Near price display</Placement>
      </PaymentOptions>
    </PriceDisplay>
    
    <VariantSelectors>
      <Colors>Circular swatches (not dropdown)</Colors>
      <Sizes>Pill-shaped buttons (not dropdown)</Sizes>
      <Rule>Avoid dropdowns—they hide options</Rule>
      
      <StockIndicators>
        <LowStock>Pulsing dot + "Low Stock" text</LowStock>
        <SoldOut>Cross out variant, label "Sold Out - Restocking Soon"</SoldOut>
        <Why>Sold out variants prove demand</Why>
      </StockIndicators>
    </VariantSelectors>
    
    <QuantityBreaks name="magnetic_middle">
      <Structure>1-Pack, 3-Pack, 6-Pack</Structure>
      <DefaultSelection>Middle option (3-Pack)</DefaultSelection>
      <Highlighting>"Best Value" or "Most Popular" ribbon</Highlighting>
      <PerUnitCopy>"Only $20.75 per treatment"</PerUnitCopy>
      <SavingsCopy>"Save $20/bottle"</SavingsCopy>
    </QuantityBreaks>
    
    <SubscribeAndSave>
      <Format>Radio button toggle</Format>
      <PreSelection>Consider pre-selecting for LTV</PreSelection>
      <IncentiveStacking>
        <Perk>Save 20%</Perk>
        <Perk>Free Shipping</Perk>
        <Perk>Priority Access</Perk>
        <Perk>Free Gifts</Perk>
      </IncentiveStacking>
      <CommitmentReduction>
        <Copy>"Pause, modify, or cancel anytime"</Copy>
        <Placement>Directly under toggle</Placement>
      </CommitmentReduction>
    </SubscribeAndSave>
  </BuyBox>

  <!-- ================================================================== -->
  <!-- ADD TO CART OPTIMIZATION                                            -->
  <!-- ================================================================== -->
  
  <AddToCart>
    <ButtonDesign>
      <Contrast>Must NOT blend with brand palette</Contrast>
      <Rule>Most visually heavy element on screen</Rule>
      <Width>Full-width on mobile</Width>
      <MicroCopy placement="below_button">
        <Examples>
          <Example>"Risk-Free Purchase"</Example>
          <Example>"Secure Checkout"</Example>
          <Example>"Ships in 24h"</Example>
        </Examples>
        <Size>10px font</Size>
        <Purpose>Neutralize last-second FUD</Purpose>
      </MicroCopy>
    </ButtonDesign>
    
    <StickyATC platform="mobile">
      <Trigger>User scrolls past main buy box</Trigger>
      <Position>Fixed bottom bar</Position>
      <Contents>
        <Element>Product Title (truncated)</Element>
        <Element>Price</Element>
        <Element>Add to Cart button</Element>
      </Contents>
      <Purpose>Checkout ability never lost</Purpose>
    </StickyATC>
    
    <TrustElements placement="near_atc">
      <SecurityIcons>"256-Bit SSL Encrypted" + card logos</SecurityIcons>
      <GuaranteeBadge>"90-Day Money-Back Guarantee"</GuaranteeBadge>
      <BenefitIcons>
        <Row>Cruelty-Free | Made in USA | Vegan</Row>
        <Format>3-4 icons with short labels</Format>
      </BenefitIcons>
    </TrustElements>
  </AddToCart>

  <!-- ================================================================== -->
  <!-- PRODUCT DESCRIPTION                                                 -->
  <!-- ================================================================== -->
  
  <ProductDescription>
    <Philosophy>Organized retrieval for Skimmers AND Readers</Philosophy>
    
    <AccordionStack>
      <Section name="key_benefits" default="open">
        <Content>3-5 bullet points, outcome-focused</Content>
        <Format>Icon + short phrase (under 8 words)</Format>
        <Example>"✓ Regrow hair in 90 days"</Example>
        <Avoid>"Contains 5mg Finasteride" (feature-only)</Avoid>
      </Section>
      
      <Section name="ingredients" default="open_if_selling_point">
        <Content>Ingredient list with benefit callouts</Content>
        <Format>Feature → Benefit translation</Format>
        <Example>"Grass-fed tallow → Mimics your skin's natural barrier"</Example>
      </Section>
      
      <Section name="how_to_use" default="closed">
        <Content>3-step simple guide</Content>
        <Format>Numbered icons with short copy</Format>
      </Section>
      
      <Section name="shipping_returns" default="closed">
        <Content>Logistics answers upfront</Content>
        <Include>Shipping time, return policy, international</Include>
      </Section>
    </AccordionStack>
    
    <FeatureToBenefit>
      <Rule>Apply "So What?" test to every feature</Rule>
      <Before>Contains 5g of Fiber</Before>
      <After>Eliminate bloating instantly</After>
    </FeatureToBenefit>
  </ProductDescription>

  <!-- ================================================================== -->
  <!-- SOCIAL PROOF SECTION                                                -->
  <!-- ================================================================== -->
  
  <SocialProof>
    <ReviewWidget>
      <MediaGrid placement="top">
        <Content>Photo/video reviews first</Content>
        <Priority>Visual evidence over text-only</Priority>
      </MediaGrid>
      
      <ReviewCards>
        <RequiredElements>
          <Element>"Verified Buyer" badge</Element>
          <Element>Star rating</Element>
          <Element>Date</Element>
          <Element>Photo (prioritized)</Element>
        </RequiredElements>
        
        <HeadlineStyle>
          <Avoid>"Great product" (generic)</Avoid>
          <Use>"My husband noticed in 2 weeks" (specific transformation)</Use>
        </HeadlineStyle>
      </ReviewCards>
      
      <Searchable>
        <Keywords>smell, shipping, specific pain points</Keywords>
        <Purpose>Let users find relevant reviews</Purpose>
      </Searchable>
    </ReviewWidget>
  </SocialProof>

  <!-- ================================================================== -->
  <!-- CROSS-SELL & UPSELL                                                 -->
  <!-- ================================================================== -->
  
  <CrossSellUpsell>
    <FrequentlyBoughtTogether>
      <Placement>Below description</Placement>
      <Format>Main product + complementary item</Format>
      <CTA>Single "Add All to Cart" button</CTA>
    </FrequentlyBoughtTogether>
    
    <InCartUpsells>
      <ProgressBar>
        <Copy>"Add $15 more to unlock Free Shipping"</Copy>
        <Visual>Progress bar showing threshold</Visual>
      </ProgressBar>
      
      <MysteryGift>
        <Copy>"Add $10 more to unlock a Free Mystery Gift"</Copy>
        <Psychology>Powerful curiosity driver</Psychology>
      </MysteryGift>
    </InCartUpsells>
  </CrossSellUpsell>

  <!-- ================================================================== -->
  <!-- QUALITY CHECKLIST                                                   -->
  <!-- ================================================================== -->
  
  <QualityChecklist>
    <Category name="Gallery">
      <Item>Hero shot is high-quality product image</Item>
      <Item>At least one benefit/result slide</Item>
      <Item>How-to-use visual included</Item>
      <Item>Social proof screenshot in carousel</Item>
      <Item>All images have embedded benefit copy</Item>
    </Category>
    
    <Category name="Buy Box">
      <Item>Star rating above product title</Item>
      <Item>Title includes benefit, not just name</Item>
      <Item>Price shows strikethrough anchoring</Item>
      <Item>Per-serving/per-day price shown</Item>
      <Item>Middle bundle pre-selected</Item>
      <Item>Subscribe perks stacked (not just %)</Item>
    </Category>
    
    <Category name="Add to Cart">
      <Item>Button contrasts with page palette</Item>
      <Item>Micro-copy below button (risk reversal)</Item>
      <Item>Sticky ATC on mobile</Item>
      <Item>Trust badges near button</Item>
    </Category>
    
    <Category name="Description">
      <Item>Accordion keeps page clean</Item>
      <Item>Benefits section open by default</Item>
      <Item>Features translated to benefits</Item>
      <Item>Icons used for scannability</Item>
    </Category>
    
    <Category name="Social Proof">
      <Item>Photo reviews prioritized</Item>
      <Item>Verified buyer badges visible</Item>
      <Item>Headline summarizes transformation</Item>
      <Item>Reviews searchable/filterable</Item>
    </Category>
  </QualityChecklist>

  <!-- ================================================================== -->
  <!-- EXECUTION OUTPUT                                                    -->
  <!-- ================================================================== -->
  
  <ExecutionOutput>
    <StitchPrompt>
      Create a product detail page with high-converting buy box.
      
      Gallery: 6-slide framework with embedded benefit copy.
      - Slide 1: Product hero
      - Slide 2: Result/transformation visual
      - Slide 3: How-to-use (1-2-3 steps)
      - Slide 4: Review screenshot
      - Slide 5: Us vs Them comparison
      - Slide 6: Guarantee badge
      
      Buy Box:
      - Star rating above title
      - Benefit-driven title
      - Price with strikethrough + per-day cost
      - Variant selectors as buttons (not dropdowns)
      - 3-tier bundle with middle pre-selected as "Best Value"
      - Subscribe toggle with stacked perks
      - High-contrast ATC button
      - Trust icons below button
      
      Mobile: Sticky ATC bar when scrolling.
      
      Description: Accordion with benefits open by default.
      Reviews: Photo reviews first, verified badges.
    </StitchPrompt>
  </ExecutionOutput>

</VerticalSkill>
