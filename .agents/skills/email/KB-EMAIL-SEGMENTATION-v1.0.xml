  <layer_1_directive>
    <philosophy>
      <principle id="1">
        <n>Relevance > Reach</n>
        <statement>Better to send relevant email to 100 than generic to 1,000</statement>
        <rationale>Irrelevant = unsubscribes; relevant = engagement + convection</rationale>
      </principle>
      
      <principle id="2">
        <n>Consciousness-Aware Routing = Differentiation</n>
        <statement>Matching content to 9D level is unique capability - the secret weapon</statement>
        <rationale>Tactical people get tactical; transformational get meaning; systems thinkers get holistic</rationale>
      </principle>
      
      <principle id="3">
        <n>Natural Elevation, No Forcing</n>
        <statement>Invite to next level, never force jumps (e.g., 2→8)</statement>
        <rationale>Forced elevation = disconnect; natural invitation = growth</rationale>
      </principle>
      
      <principle id="4">
        <n>Behavioral Data = Service, Not Exploitation</n>
        <statement>Engagement data serves subscribers (relevant content), not exploits</statement>
        <rationale>Ethical use builds trust; exploitation destroys relationship</rationale>
      </principle>
    </philosophy>
    
    <standards>
      <standard id="behavioral_segmentation">
        <segments>
          <hot>70%+ opens last 30 days, 3+ clicks, opened within 7 days</hot>
          <warm>30-70% opens, 1-2 clicks, opened within 30 days</warm>
          <cold><30% opens OR no opens 90+ days</cold>
        </segments>
        <validation_tool>assess_engagement_level()</validation_tool>
      </standard>
      
      <standard id="consciousness_routing">
        <detection>Language analysis, engagement patterns, purchase history, surveys</detection>
        <routing>
          <rule>IF Level 1-3 THEN tactical content</rule>
          <rule>IF Level 4-6 THEN transformation content</rule>
          <rule>IF Level 7-9 THEN systems content</rule>
        </routing>
        <validation_tool>route_by_consciousness()</validation_tool>
      </standard>
      
      <standard id="dynamic_personalization">
        <tokens>{name}, {challenge}, {goal}, {industry}, {days_subscribed}</tokens>
        <conditional_blocks>IF/ELIF/ELSE based on engagement, level, journey</conditional_blocks>
        <validation_tool>personalize_content()</validation_tool>
      </standard>
    </standards>
    
    <guardrails>
      <guardrail id="no_forced_elevation" severity="high">
        <rule>No 1→9 jumps; max 2 levels at a time</rule>
      </guardrail>
      
      <guardrail id="ethical_data_use" severity="high">
        <rule>Data for service (relevance), not exploitation (manipulation)</rule>
      </guardrail>
      
      <guardrail id="personalization_boundaries" severity="medium">
        <rule>Use stated/permissioned data, not inferred secrets</rule>
      </guardrail>
    </guardrails>
  </layer_1_directive>
  
