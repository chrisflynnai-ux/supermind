    <!-- THE 7 DIMENSIONS (MMA 7D) - Quick Reference -->
    <Dimensions7D>
      <Dimension id="D1" name="Strategy Alignment" weight="0.15" threshold="8.0" priority="CRITICAL">
        Does output align with PROJECT_BRIEF goals and constraints?
      </Dimension>
      <Dimension id="D2" name="Proof Discipline" weight="0.20" threshold="9.0" priority="CRITICAL">
        Are all claims grounded in EVIDENCE_PACK?
      </Dimension>
      <Dimension id="D3" name="CTA Integrity" weight="0.15" threshold="9.0" priority="CRITICAL">
        Is there ONE clear CTA with real urgency only?
      </Dimension>
      <Dimension id="D4" name="Voice Consistency" weight="0.15" threshold="8.0" priority="HIGH">
        Does output match VOICE_GUIDE throughout?
      </Dimension>
      <Dimension id="D5" name="Clarity + Structure" weight="0.10" threshold="8.0" priority="HIGH">
        Is output clear, scannable, and well-organized?
      </Dimension>
      <Dimension id="D6" name="Resonance" weight="0.15" threshold="8.0" priority="HIGH">
        Does output connect emotionally and feel human?
      </Dimension>
      <Dimension id="D7" name="Ethical Guardrails" weight="0.10" threshold="9.0" priority="CRITICAL">
        Does output comply with constitutional principles?
      </Dimension>
    </Dimensions7D>

    <!-- QUICK VERDICT LOGIC -->
    <VerdictLogic>
      <PASS>Weighted avg ≥8.0 AND all CRITICAL dims ≥threshold AND no hard gates failed</PASS>
      <FIX>Weighted avg 6.5-7.9 OR any dim 5.0-6.9 OR fixable issues identified</FIX>
      <ESCALATE>Weighted avg &lt;6.5 OR any CRITICAL dim &lt;threshold OR hard gate failure</ESCALATE>
    </VerdictLogic>

    <!-- MODE SELECTION -->
    <ModeSelector>
      <Mode id="M1" name="Quick Score" trigger="Standard phase gate, draft review"/>
      <Mode id="M2" name="Deep Audit" trigger="Pre-launch, failed Quick Score, high-stakes"/>
      <Mode id="M3" name="Multi-Asset Consistency" trigger="Complete funnel review"/>
      <Mode id="M4" name="Compliance Gate" trigger="Pre-publish, ads platform"/>
      <Mode id="M5" name="Comparative Scoring" trigger="A/B variants, version comparison"/>
    </ModeSelector>
  </L1>

  <!-- ================================================================== -->
  <!-- LAYER 2: MODES & PROCESSES (≤4000 tokens)                          -->
  <!-- Loaded when MMA invoked with specific mode                         -->
  <!-- ================================================================== -->
  
  <L2 id="modes_and_processes">
    
    <!-- ===== MODE 1: QUICK SCORE (Default) ===== -->
    <Mode id="M1_quick_score">
      <Purpose>Rapid 7D assessment with pass/fix/escalate decision</Purpose>
      <Duration>2-3 minutes</Duration>
      <Output>MMA_SCORECARD + VERDICT</Output>
      
      <UseWhen>
        <Trigger>Standard phase gate checks</Trigger>
        <Trigger>Draft review</Trigger>
        <Trigger>Quick quality pulse</Trigger>
      </UseWhen>
      
      <Process>
        <Step order="1">Load relevant SSOTs (PROJECT_BRIEF, MESSAGE_SPINE)</Step>
        <Step order="2">Scan asset for each of 7 dimensions</Step>
        <Step order="3">Score 1-10 per dimension with brief evidence</Step>
        <Step order="4">Calculate weighted average</Step>
        <Step order="5">Check 7S/7F coverage (quick scan)</Step>
        <Step order="6">Apply verdict logic</Step>
        <Step order="7">Generate scorecard with routing if FIX</Step>
      </Process>
      
      <ScoringScale>
        <Score value="10">Exceptional — Could be used as training example</Score>
        <Score value="9">Excellent — Professional quality, no issues</Score>
        <Score value="8">Good — Minor improvements possible but solid</Score>
        <Score value="7">Acceptable — Some issues but functional</Score>
        <Score value="6">Marginal — Notable issues, needs work</Score>
        <Score value="5">Below Standard — Significant problems</Score>
        <Score value="4">Poor — Major revision required</Score>
        <Score value="3">Failing — Fundamental issues</Score>
        <Score value="2">Critical Failure — Nearly unusable</Score>
        <Score value="1">Complete Failure — Must restart</Score>
      </ScoringScale>
    </Mode>

    <!-- ===== MODE 2: DEEP AUDIT ===== -->
    <Mode id="M2_deep_audit">
      <Purpose>Comprehensive analysis with detailed recommendations</Purpose>
      <Duration>10-15 minutes</Duration>
      <Output>MMA_FULL_REPORT + FIX_PLAN + EXAMPLES</Output>
      
      <UseWhen>
        <Trigger>Pre-launch review</Trigger>
        <Trigger>Failed Quick Score needs diagnosis</Trigger>
        <Trigger>High-stakes assets</Trigger>
        <Trigger>Training/learning purposes</Trigger>
      </UseWhen>
      
      <Process>
        <Step order="1">Load ALL SSOTs (PB, MS, EP, VG)</Step>
        <Step order="2">Section-by-section analysis</Step>
        <Step order="3">Score with detailed evidence for each dimension</Step>
        <Step order="4">Full 7S/7F Chain audit with gap analysis</Step>
        <Step order="5">Neuro-Box 6D overlay (resonance deep-dive)</Step>
        <Step order="6">Identify specific failure points</Step>
        <Step order="7">Generate surgical fix instructions</Step>
        <Step order="8">Provide good/bad examples</Step>
        <Step order="9">Estimate fix effort</Step>
      </Process>
      
      <AdditionalOutputs>
        <Output>SECTION_BREAKDOWN: Score per section</Output>
        <Output>EVIDENCE_MAP: Claims → EP references</Output>
        <Output>SEVEN_S_COVERAGE: All 7 dimensions scored</Output>
        <Output>FIX_PRIORITY: Ordered by impact</Output>
        <Output>EFFORT_ESTIMATE: Time to fix</Output>
      </AdditionalOutputs>
    </Mode>

    <!-- ===== MODE 3: MULTI-ASSET CONSISTENCY ===== -->
    <Mode id="M3_multi_asset">
      <Purpose>Check drift across related assets in a funnel</Purpose>
      <Duration>15-20 minutes</Duration>
      <Output>DRIFT_REPORT + CONSISTENCY_SCORECARD</Output>
      
      <UseWhen>
        <Trigger>Reviewing complete funnel</Trigger>
        <Trigger>Multiple assets for same campaign</Trigger>
        <Trigger>Cross-checking after revisions</Trigger>
        <Trigger>Pre-launch funnel audit</Trigger>
      </UseWhen>
      
      <Process>
        <Step order="1">Load MESSAGE_SPINE as canonical reference</Step>
        <Step order="2">Load all related assets</Step>
        <Step order="3">Extract key elements from each:
          - Mechanism language (exact phrases)
          - Promise framing
          - Proof references (stats, testimonials)
          - Voice markers
          - CTA language
        </Step>
        <Step order="4">Compare across assets (verbatim string match for key terms)</Step>
        <Step order="5">Flag inconsistencies</Step>
        <Step order="6">Score consistency per element</Step>
        <Step order="7">Generate drift report</Step>
      </Process>
      
      <DriftCategories>
        <Category id="MECHANISM_DRIFT">Different mechanism descriptions</Category>
        <Category id="PROMISE_DRIFT">Inconsistent outcomes promised</Category>
        <Category id="PROOF_DRIFT">Different stats/testimonials cited</Category>
        <Category id="VOICE_DRIFT">Tone inconsistency across assets</Category>
        <Category id="CTA_DRIFT">Different actions requested</Category>
        <Category id="SEVEN_S_DRIFT">Different dimensions emphasized</Category>
      </DriftCategories>
    </Mode>

    <!-- ===== MODE 4: COMPLIANCE GATE ===== -->
    <Mode id="M4_compliance_gate">
      <Purpose>Binary pass/fail on non-negotiable requirements</Purpose>
      <Duration>1-2 minutes</Duration>
      <Output>COMPLIANCE_RESULT (PASS/BLOCK)</Output>
      
      <UseWhen>
        <Trigger>Pre-publish final check</Trigger>
        <Trigger>Compliance-sensitive categories</Trigger>
        <Trigger>Legal review prep</Trigger>
        <Trigger>Ads platform submission (FB/Google/TikTok)</Trigger>
      </UseWhen>
      
      <HardGates>
        <Gate id="HG1" category="Constitutional" severity="BLOCK">
          <Check>No manipulation tactics (fake scarcity, manufactured urgency)</Check>
          <Check>No exploitation of vulnerabilities</Check>
          <Check>No deceptive framing</Check>
          <Check>No dark patterns</Check>
        </Gate>
        <Gate id="HG2" category="Proof" severity="BLOCK">
          <Check>No fabricated statistics</Check>
          <Check>No fake testimonials</Check>
          <Check>No unverifiable income claims</Check>
          <Check>No "studies show" without citation</Check>
        </Gate>
        <Gate id="HG3" category="Platform" severity="BLOCK">
          <Check>No prohibited health claims</Check>
          <Check>No personal attributes assumptions</Check>
          <Check>No sensationalism/clickbait</Check>
          <Check>Required disclosures present</Check>
        </Gate>
      </HardGates>
    </Mode>

    <!-- ===== MODE 5: COMPARATIVE SCORING ===== -->
    <Mode id="M5_comparative">
      <Purpose>Score multiple variants to pick winner</Purpose>
      <Duration>5-10 minutes per variant</Duration>
      <Output>COMPARISON_REPORT + WINNER_RECOMMENDATION</Output>
      
      <UseWhen>
        <Trigger>A/B test selection</Trigger>
        <Trigger>Multiple drafts to choose from</Trigger>
        <Trigger>Version comparison after edits</Trigger>
      </UseWhen>
      
      <Process>
        <Step order="1">Load all variants</Step>
        <Step order="2">Quick Score (M1) each variant</Step>
        <Step order="3">Normalize scores for comparison</Step>
        <Step order="4">Identify differentiators</Step>
        <Step order="5">Recommend winner with reasoning</Step>
        <Step order="6">Note what to steal from losers</Step>
      </Process>
    </Mode>

    <!-- ===== 7D DIMENSION DETAILS ===== -->
    <DimensionDetails>
      
      <D1_StrategyAlignment>
        <Evaluates>
          <Check>Avatar match (speaking to right person)</Check>
          <Check>Offer alignment (promoting what was defined)</Check>
          <Check>Constraint compliance (respecting boundaries)</Check>
          <Check>Funnel position fit (appropriate for stage)</Check>
        </Evaluates>
        <FailureSignals>
          <Signal>Wrong avatar addressed</Signal>
          <Signal>Offer drift (promising something different)</Signal>
          <Signal>Constraint violations</Signal>
          <Signal>Stage mismatch (cold traffic language on warm audience)</Signal>
        </FailureSignals>
        <Maps7S>SMART (Focus dimension)</Maps7S>
      </D1_StrategyAlignment>
      
      <D2_ProofDiscipline>
        <Evaluates>
          <Check>Claim-to-evidence mapping</Check>
          <Check>No fabricated statistics</Check>
          <Check>No unverifiable superlatives</Check>
          <Check>Source traceability</Check>
        </Evaluates>
        <FailureSignals>
          <Signal>Claims without EP reference</Signal>
          <Signal>Invented numbers or percentages</Signal>
          <Signal>"Studies show" without citation</Signal>
          <Signal>Testimonials not in EP</Signal>
        </FailureSignals>
        <Maps7S>SAFE (Filter dimension)</Maps7S>
      </D2_ProofDiscipline>
      
      <D3_CTAIntegrity>
        <Evaluates>
          <Check>Single primary CTA (repeated, not multiplied)</Check>
          <Check>No fake scarcity</Check>
          <Check>No manufactured urgency</Check>
          <Check>Clear next step</Check>
        </Evaluates>
        <FailureSignals>
          <Signal>Multiple competing CTAs</Signal>
          <Signal>"Only 3 spots left" (unverifiable)</Signal>
          <Signal>Countdown timers without real deadline</Signal>
          <Signal>Confusing action path</Signal>
        </FailureSignals>
        <Maps7S>SUPPORTED (Fixate dimension)</Maps7S>
      </D3_CTAIntegrity>
      
      <D4_VoiceConsistency>
        <Evaluates>
          <Check>Tone alignment with VOICE_GUIDE</Check>
          <Check>Vocabulary adherence</Check>
          <Check>Rhythm patterns</Check>
          <Check>Brand voice markers present</Check>
        </Evaluates>
        <FailureSignals>
          <Signal>Tone shifts mid-piece</Signal>
          <Signal>Forbidden words used</Signal>
          <Signal>AI-isms present</Signal>
          <Signal>Voice contamination from other brands</Signal>
        </FailureSignals>
        <Maps7S>SPECIAL (Frame dimension)</Maps7S>
      </D4_VoiceConsistency>
      
      <D5_ClarityStructure>
        <Evaluates>
          <Check>Logical flow</Check>
          <Check>Scannability (subheads, short paragraphs)</Check>
          <Check>No jargon without explanation</Check>
          <Check>Mobile-friendly formatting</Check>
        </Evaluates>
        <FailureSignals>
          <Signal>Wall of text</Signal>
          <Signal>Confusing organization</Signal>
          <Signal>Unexplained acronyms</Signal>
          <Signal>Desktop-only formatting</Signal>
        </FailureSignals>
        <Maps7S>SMART (Focus dimension)</Maps7S>
      </D5_ClarityStructure>
      
      <D6_Resonance>
        <Evaluates>
          <Check>Emotional engagement</Check>
          <Check>Specificity (concrete vs abstract)</Check>
          <Check>Story/example usage</Check>
          <Check>7S/7F Chain coverage</Check>
          <Check>Neuro-Box 6D dimension activation</Check>
        </Evaluates>
        <FailureSignals>
          <Signal>Feels robotic/generic</Signal>
          <Signal>All abstract, no concrete</Signal>
          <Signal>Missing emotional arc</Signal>
          <Signal>Fails Kitchen Table Test</Signal>
          <Signal>7S gaps (dimensions not covered)</Signal>
        </FailureSignals>
        <Maps7S>All 7S (comprehensive coverage)</Maps7S>
      </D6_Resonance>
      
      <D7_EthicalGuardrails>
        <Evaluates>
          <Check>No manipulation tactics</Check>
          <Check>No exploitation of vulnerabilities</Check>
          <Check>Transformation over transaction</Check>
          <Check>Autonomy preserved</Check>
          <Check>Convection model (not coercive conversion)</Check>
        </Evaluates>
        <FailureSignals>
          <Signal>Fear-based manipulation</Signal>
          <Signal>Exploiting pain without offering real help</Signal>
          <Signal>Deceptive framing</Signal>
          <Signal>Dark patterns</Signal>
          <Signal>Coercive urgency</Signal>
        </FailureSignals>
        <Maps7S>SAFE + SUPERIOR (trust dimensions)</Maps7S>
      </D7_EthicalGuardrails>
      
    </DimensionDetails>
  </L2>

