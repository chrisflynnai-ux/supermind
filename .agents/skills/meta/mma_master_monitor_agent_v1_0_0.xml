  <!-- LAYER 3: 7S/7F INTEGRATION + OUTPUTS (≤3000 tokens)                -->
  <!-- Loaded for Deep Audit or when 7S coverage requested                -->
  <!-- ================================================================== -->
  
  <L3 id="seven_s_integration_and_outputs">
    
    <!-- ===== 7S/7F CHAIN AUDIT ===== -->
    <SevenSChainAudit>
      <Overview>
        MMA validates that all 7S dimensions are adequately covered based on asset type.
        Different assets emphasize different dimensions — MMA checks appropriate coverage.
      </Overview>
      
      <DimensionRequirements>
        <SevenS id="1" name="SAFE" axis="A" neuro="BODY" threshold="8.0">
          <Question>Am I safe here? Not being scammed?</Question>
          <ChecksFor>
            <Check>Risk reversal (guarantee, refund policy)</Check>
            <Check>Credentials/authority markers</Check>
            <Check>Validation language ("You're not alone")</Check>
            <Check>Trust signals early in content</Check>
          </ChecksFor>
          <MMA_Dimension>D2 (Proof Discipline) + D7 (Ethical)</MMA_Dimension>
        </SevenS>
        
        <SevenS id="2" name="SPECIAL" axis="A" neuro="HEART" threshold="7.5">
          <Question>Is this unique? Will I feel alive?</Question>
          <ChecksFor>
            <Check>Exclusive positioning ("Not for everyone")</Check>
            <Check>Emotional language (vivid, sensory)</Check>
            <Check>Personal stories creating connection</Check>
            <Check>Transformation identity framing</Check>
          </ChecksFor>
          <MMA_Dimension>D4 (Voice) + D6 (Resonance)</MMA_Dimension>
        </SevenS>
        
        <SevenS id="3" name="SMART" axis="B" neuro="MIND" threshold="9.0" critical="true">
          <Question>Does this make sense? Am I making a good choice?</Question>
          <ClarityIsEverything>*** CRITICAL DIMENSION ***</ClarityIsEverything>
          <ChecksFor>
            <Check>Clear mechanism explanation</Check>
            <Check>Data/stats proving it works</Check>
            <Check>Value justification (worth the price)</Check>
            <Check>Process clarity ("Here's exactly what happens")</Check>
            <Check>Logical structure (numbered steps, clear flow)</Check>
          </ChecksFor>
          <MMA_Dimension>D1 (Strategy) + D5 (Clarity)</MMA_Dimension>
        </SevenS>
        
        <SevenS id="4" name="SIGNIFICANT" axis="B" neuro="SPIRIT" threshold="7.5">
          <Question>Do others want this? Will this matter?</Question>
          <ChecksFor>
            <Check>Social proof (testimonials, case studies)</Check>
            <Check>Community signals ("Join thousands")</Check>
            <Check>Significance framing ("This changes everything")</Check>
            <Check>Third-party validation (media, experts)</Check>
          </ChecksFor>
          <MMA_Dimension>D2 (Proof) + D6 (Resonance)</MMA_Dimension>
        </SevenS>
        
        <SevenS id="5" name="SUPPORTED" axis="C" neuro="PSYCHE" threshold="8.0">
          <Question>Can I act NOW? Is the path clear?</Question>
          <ChecksFor>
            <Check>Clear CTA (single, prominent)</Check>
            <Check>Real urgency only (actual deadlines)</Check>
            <Check>Path clarity ("Here's exactly what to do")</Check>
            <Check>Friction removal (easy process)</Check>
          </ChecksFor>
          <MMA_Dimension>D3 (CTA Integrity)</MMA_Dimension>
        </SevenS>
        
        <SevenS id="6" name="SUPERIOR" axis="C" neuro="CONSCIENCE" threshold="7.0">
          <Question>Am I supported? Do I belong?</Question>
          <ChecksFor>
            <Check>Community emphasis ("Join our community")</Check>
            <Check>Support promises ("We're here for you")</Check>
            <Check>Team introductions (human connection)</Check>
            <Check>Belonging language ("You're one of us")</Check>
          </ChecksFor>
          <MMA_Dimension>D6 (Resonance) + D7 (Ethical)</MMA_Dimension>
        </SevenS>
        
        <SevenS id="7" name="STEAL" axis="CENTER" neuro="SOUL" threshold="7.0">
          <Question>Is this an incredible deal?</Question>
          <ChecksFor>
            <Check>Value stack so good it feels like stealing</Check>
            <Check>Price anchoring (compare to higher value)</Check>
            <Check>Bundle magic (more for less)</Check>
            <Check>Bonus stacking</Check>
          </ChecksFor>
          <MMA_Dimension>D1 (Strategy) + D3 (CTA)</MMA_Dimension>
        </SevenS>
      </DimensionRequirements>
      
      <AssetTypeRequirements>
        <AssetType name="Advertorial">
          <Primary threshold="9.0">SAFE, SPECIAL</Primary>
          <Secondary threshold="7.5">SMART (tease only)</Secondary>
          <Note>Advertorials bridge cold → warm, focus on trust + intrigue</Note>
        </AssetType>
        
        <AssetType name="Sales Page">
          <Primary threshold="9.0">SMART, SIGNIFICANT, SUPPORTED</Primary>
          <Secondary threshold="8.0">SAFE, STEAL</Secondary>
          <Tertiary threshold="7.0">SPECIAL, SUPERIOR</Tertiary>
          <Note>Sales pages must cover ALL 7 dimensions</Note>
        </AssetType>
        
        <AssetType name="VSL">
          <Primary threshold="9.0">SAFE, SPECIAL, SMART</Primary>
          <Secondary threshold="8.0">SIGNIFICANT, SUPPORTED</Secondary>
          <Tertiary threshold="7.0">SUPERIOR, STEAL</Tertiary>
          <Note>VSL follows belief-building arc through all dimensions</Note>
        </AssetType>
        
        <AssetType name="Email">
          <Varies>By email type (Welcome=SAFE/SPECIAL, Nurture=SMART/SIGNIFICANT, Launch=SUPPORTED/STEAL)</Varies>
        </AssetType>
      </AssetTypeRequirements>
    </SevenSChainAudit>

