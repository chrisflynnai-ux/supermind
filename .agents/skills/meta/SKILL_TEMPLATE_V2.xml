  <!-- VERSION HISTORY                                                       -->
  <!-- ===================================================================== -->

  <VersionHistory>
    <Version number="[version]" date="[YYYY-MM-DD]">
      <Status>[draft|beta|active]</Status>
      <Changes>
        <Change type="[feature|bugfix|enhancement]">[Description]</Change>
      </Changes>
      <BaselineScores>
        <Dimension name="strategy_alignment">0.0</Dimension>
        <Dimension name="clarity_structure">0.0</Dimension>
        <Dimension name="voice_consistency">0.0</Dimension>
        <Dimension name="proof_discipline">0.0</Dimension>
        <Dimension name="neuro_resonance">0.0</Dimension>
        <Dimension name="cta_integrity">0.0</Dimension>
        <Dimension name="ethical_guardrails">0.0</Dimension>
        <Average>0.0</Average>
      </BaselineScores>
    </Version>
  </VersionHistory>

</Skill>
